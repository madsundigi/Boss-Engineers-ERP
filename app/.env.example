# Copy to .env.
PORT=3001
NODE_ENV=development

# Database. IMPORTANT (RLS): in production the login user MUST be a member of the
# non-superuser role `erp_app` (GRANT erp_app TO <login_user>) — the app does
# `SET LOCAL ROLE erp_app` per transaction so Row-Level Security is enforced.
# Connecting as a superuser/owner bypasses RLS and is for local dev/test only.
DATABASE_URL=postgres://postgres@localhost:5432/be

# Authentication. When set, every /api request MUST carry a verified
# `Authorization: Bearer <jwt>` (no header fallback). REQUIRED in production —
# without it the app fails closed (NODE_ENV=production rejects header identity).
# AUTH_JWT_SECRET=change-me

# Email (optional). If unset, outbound mail goes to an in-memory outbox.
# SMTP_URL=smtps://user:pass@smtp.example.com:465
# MAIL_FROM=no-reply@boss-erp.local

# LOG_LEVEL=info
